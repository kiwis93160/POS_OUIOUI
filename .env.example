# Base path for Netlify serverless functions. Leave as default when deploying on Netlify.
VITE_NETLIFY_FUNCTIONS_BASE=/.netlify/functions

# Supabase configuration
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# Optional: table that stores site asset key/value pairs
VITE_SUPABASE_SITE_ASSETS_TABLE=site_assets

# Cloudinary configuration
VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_UPLOAD_PRESET=
